# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
SUPABASE_SECRET_KEY=sb_secret_xxx

# Redis
REDIS_URL=redis://127.0.0.1:6379

# API
API_PORT=3001
API_HOST=0.0.0.0
CORS_ORIGIN=http://localhost:5173

# Web
VITE_API_URL=http://localhost:3001
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# Feature flags (web)
# Routing Studio — unified routing admin page (simulator + coverage matrix).
# Off by default; safe to leave off in production until the whole Studio ships.
VITE_FEATURE_ROUTING_STUDIO=false

# AI (Phase 2+)
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# Frontend base URL — used for OAuth redirects + emails that link back into
# the app. In production this is the canonical origin (no trailing slash).
FRONTEND_BASE_URL=http://localhost:5173

# ─── Calendar sync (Microsoft Graph / Outlook) — Phase H ───────────────────
# Token-at-rest encryption key for OAuth tokens stored in
# public.calendar_sync_links. Required. Falls back to SUPABASE_VAULT_KEY if
# unset; one of the two MUST be set or the calendar-sync module fails to start.
CALENDAR_TOKEN_ENCRYPTION_KEY=

# Microsoft Entra (Azure AD) app registration credentials. The redirect URI
# must match exactly what the app registration has on file.
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
# 'common' for multi-tenant, 'organizations' for any work/school account, or
# the tenant GUID for single-tenant deployments.
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URI=http://localhost:5173/portal/calendar-sync/callback

# Microsoft Graph push-subscription endpoint. Must be HTTPS in production.
# In dev use ngrok or similar. The clientState is echoed back by Graph in
# every notification — we use it to verify the source.
MICROSOFT_GRAPH_WEBHOOK_URL=https://example.ngrok.io/api/webhooks/outlook
MICROSOFT_GRAPH_WEBHOOK_CLIENT_STATE=change-me-to-a-long-random-string

# ─── Resend (transactional email) — B.4.A.5 ───────────────────────────────
# EU-region API key (required for the notifications + visitors + daily-list
# mail flows). The MailModule selects ResendMailProvider when this is set,
# otherwise it falls back to the dev LoggingMailProvider. Provision via
# https://resend.com — choose the EU region for GDPR data residency.
RESEND_API_KEY=
# Default FROM address for notifications. Must be a verified domain on the
# Resend account. Static per architect I2 — no <tenant.domain> resolution
# in v1. Falls back to RESEND_DEFAULT_FROM_EMAIL (used by daily-list +
# vendor-portal flows) if unset, then to notifications@prequest.app.
RESEND_FROM_EMAIL=notifications@prequest.app
# Display name shown in the email envelope. Defaults to "Prequest" when unset.
RESEND_FROM_NAME=Prequest

# Existing Resend env vars used by the daily-list + vendor-portal flows.
# Leave alongside RESEND_FROM_EMAIL for backwards compatibility — the
# notifications module reads RESEND_FROM_EMAIL first, then falls back.
RESEND_DEFAULT_FROM_EMAIL=
RESEND_DEFAULT_FROM_NAME=Prequest
RESEND_WEBHOOK_SECRET=
