    "ioredis": "^5.6.0",
    "isomorphic-dompurify": "^3.9.0",
    "luxon": "^3.7.2",
    "multer": "^2.1.1",
    "pg": "^8.20.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
