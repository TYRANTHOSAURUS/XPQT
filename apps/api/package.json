    "smoke:cancel-booking": "node scripts/smoke-cancel-booking.mjs",
    "smoke:create-multi-room": "node scripts/smoke-create-multi-room.mjs",
    "smoke:visual-approval": "node scripts/smoke-visual-approval.mjs",
    "smoke:cross-tenant": "node scripts/smoke-cross-tenant.mjs"
