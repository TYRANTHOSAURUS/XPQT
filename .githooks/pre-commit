#!/usr/bin/env bash
#
# pre-commit — enforce design polish + B.2 config-reads rules before
# a commit lands.
#
# Each script supports --staged and skips cleanly if no relevant files
# are staged. Both are grep-based and complete in under a second.
#
# Skips automatically during rebase / cherry-pick / merge so those
# replay operations never block.
#
# Bypass in a genuine emergency with `git commit --no-verify`, but
# follow up with a fix commit — the checks are run in CI regardless.

set -euo pipefail

# Skip during non-committing operations.
if [ -f "$(git rev-parse --git-dir)/MERGE_HEAD" ] \
  || [ -f "$(git rev-parse --git-dir)/CHERRY_PICK_HEAD" ] \
  || [ -f "$(git rev-parse --git-dir)/rebase-merge" ] \
  || [ -f "$(git rev-parse --git-dir)/rebase-apply" ]; then
  exit 0
fi

ROOT="$(git rev-parse --show-toplevel)"

# Sequential — each script exits non-zero on violation; pre-commit
# aborts at the first failure.
bash "$ROOT/scripts/check-design.sh" --staged
bash "$ROOT/scripts/check-b2-config-reads.sh" --staged
